<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="613.0" prefWidth="465.0" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.example.demo1.HelloController">
   <children>
      <MenuBar>
        <menus>
          <Menu mnemonicParsing="false" text="File">
            <items>
              <MenuItem mnemonicParsing="false" text="Close" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Edit">
            <items>
              <MenuItem mnemonicParsing="false" text="Delete" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Help">
            <items>
              <MenuItem mnemonicParsing="false" text="About" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
      <Label alignment="TOP_LEFT" prefHeight="55.0" prefWidth="425.0" text="Zpráva úkolů">
         <font>
            <Font size="21.0" />
         </font>
      </Label>
      <HBox prefHeight="530.0" prefWidth="425.0">
         <children>
            <VBox prefHeight="439.0" prefWidth="218.0">
               <children>
                  <Label text="Zadej nazev Úkolu:">
                     <VBox.margin>
                        <Insets bottom="5.0" />
                     </VBox.margin>
                  </Label>
                  <TextField fx:id="nazevUkolu" prefHeight="25.0" prefWidth="138.0">
                     <VBox.margin>
                        <Insets bottom="10.0" right="5.0" />
                     </VBox.margin>
                  </TextField>
                  <Label text="Vyber předmět Úkolu:">
                     <VBox.margin>
                        <Insets bottom="5.0" />
                     </VBox.margin>
                  </Label>
                  <RadioButton fx:id="ANJ" mnemonicParsing="false" text="Anglictina">
                     <VBox.margin>
                        <Insets bottom="5.0" />
                     </VBox.margin>
                     <toggleGroup>
                        <ToggleGroup fx:id="predmet" />
                     </toggleGroup>
                  </RadioButton>
                  <RadioButton fx:id="MAT" mnemonicParsing="false" text="Matika" toggleGroup="$predmet">
                     <VBox.margin>
                        <Insets bottom="5.0" />
                     </VBox.margin>
                  </RadioButton>
                  <RadioButton fx:id="CES" mnemonicParsing="false" text="Cestina" toggleGroup="$predmet">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </RadioButton>
                  <Label text="Vyber prioritu Úkolu:">
                     <VBox.margin>
                        <Insets bottom="5.0" />
                     </VBox.margin>
                  </Label>
                  <RadioButton fx:id="specha" mnemonicParsing="false" text="Spěchá">
                     <VBox.margin>
                        <Insets bottom="5.0" />
                     </VBox.margin>
                     <toggleGroup>
                        <ToggleGroup fx:id="priorita" />
                     </toggleGroup>
                  </RadioButton>
                  <RadioButton fx:id="mamCas" mnemonicParsing="false" text="Ještě mám čas" toggleGroup="$priorita">
                     <VBox.margin>
                        <Insets bottom="5.0" />
                     </VBox.margin>
                  </RadioButton>
                  <RadioButton fx:id="bezTerminu" mnemonicParsing="false" text="Bez termínu" toggleGroup="$priorita">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </RadioButton>
                  <Label text="Splněno:">
                     <VBox.margin>
                        <Insets bottom="5.0" />
                     </VBox.margin>
                  </Label>
                  <CheckBox fx:id="checkUkolu" mnemonicParsing="false" text="Ano/Ne">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </CheckBox>
                  <Button fx:id="odeslani" mnemonicParsing="false" onAction="#onOdeslatButtonClick" text="Odeslat">
                     <VBox.margin>
                        <Insets bottom="5.0" />
                     </VBox.margin>
                  </Button>
                  <Label fx:id="info" alignment="TOP_LEFT" prefHeight="158.0" prefWidth="192.0" text="Informace:">
                     <VBox.margin>
                        <Insets top="20.0" />
                     </VBox.margin>
                  </Label>
               </children>
            </VBox>
            <ListView fx:id="lstUkolu" onMouseClicked="#onClick" prefHeight="261.0" prefWidth="259.0" />
         </children>
         <VBox.margin>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </VBox.margin>
      </HBox>
   </children>
</VBox>
